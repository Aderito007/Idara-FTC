
QDockWidget {
    background-color: #1F4E79;
}

QPushButton {
    background-color: #267324ff;
    color: white;
    border: none;
    padding: 10px;
    text-align: left;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #163A5F;
}    

QGroupBox {
    font-weight: bold;
    border: 1px solid #1F4E79;
    margin-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 5px;
    color: #1F4E79;
}
QLineEdit, QComboBox, QDateEdit {
    padding: 4px;
    border: 1px solid #CCC;
    border-radius: 4px;
}
QPushButton {
    background-color: #2A82DA;
    color: white;
    padding: 6px 12px;
    border-radius: 4px;
}
QTreeView::item {
    padding: 6px;
    border-bottom: 1px solid #DDD;
}
QTreeView::item:selected {
    background-color: #1F4E79;
    color: white;
}